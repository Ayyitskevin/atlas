# Copy to /etc/atlas/atlas.env, fill real values, then install as 0640 root:atlas.
# The maintenance services import the same environment as the API because the
# cleanup command uses the shared Atlas config parser and object-storage client.

NODE_ENV=production
API_HOST=0.0.0.0
API_PORT=4000
WEB_ORIGIN=https://atlas.example.com
LOG_LEVEL=info
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW="1 minute"

# Required in production even for maintenance commands because Atlas validates
# the shared runtime environment at import time.
JWT_ACCESS_SECRET=replace-with-a-unique-32-plus-character-access-secret
JWT_REFRESH_SECRET=replace-with-a-unique-32-plus-character-refresh-secret

DATABASE_URL=postgresql://atlas:replace-with-database-password@127.0.0.1:5432/atlas
REDIS_URL=redis://127.0.0.1:6379

EMAIL_PROVIDER=noop
EMAIL_FROM=no-reply@atlas.example.com
RESEND_API_KEY=
RESEND_API_URL=https://api.resend.com

S3_ENDPOINT=https://s3.example.com
S3_PUBLIC_ENDPOINT=https://s3.example.com
S3_BUCKET=atlas-production
S3_ACCESS_KEY_ID=replace-with-access-key
S3_SECRET_ACCESS_KEY=replace-with-secret-key
S3_REGION=us-east-1

ATTACHMENT_SCAN_PROVIDER=noop
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_MS=10000

ATLAS_PENDING_UPLOAD_TTL_HOURS=24
ATLAS_DELETED_ATTACHMENT_OBJECT_RETENTION_DAYS=30
