# Atlas local development environment

# API
NODE_ENV=development
API_HOST=0.0.0.0
API_PORT=4000
WEB_ORIGIN=http://localhost:3000
LOG_LEVEL=info
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW=1 minute

# Auth
# Production startup fails unless these are unique, non-placeholder values of at least 32 characters.
JWT_ACCESS_SECRET=replace-with-a-long-local-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-local-refresh-secret

# Optional host ports for Docker Compose
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379
MINIO_API_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001
API_HOST_PORT=4000
WEB_HOST_PORT=3000
CLAMAV_HOST_PORT=3310

# Database
DATABASE_URL=postgresql://atlas:atlas@postgres:5432/atlas

# Redis / BullMQ
REDIS_URL=redis://redis:6379

# Email
EMAIL_PROVIDER=noop
EMAIL_FROM=no-reply@atlas.local
# Set EMAIL_PROVIDER=resend and provide a real key/from domain to send externally.
RESEND_API_KEY=
RESEND_API_URL=https://api.resend.com

# Object storage
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_BUCKET=atlas-local
S3_ACCESS_KEY_ID=atlas
S3_SECRET_ACCESS_KEY=atlas-password
S3_REGION=us-east-1
ATTACHMENT_SCAN_PROVIDER=noop
# Set ATTACHMENT_SCAN_PROVIDER=clamav to stream completed uploads to clamd before activation.
# For host-run API/preflight commands, keep CLAMAV_HOST=127.0.0.1. For Docker Compose API containers, use CLAMAV_HOST=clamav.
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_MS=10000

# Web
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:4000/api/v1/ws
