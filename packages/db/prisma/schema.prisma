generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  GUEST
}

enum ProjectRole {
  PROJECT_ADMIN
  EDITOR
  COMMENTER
  VIEWER
}

enum ProjectVisibility {
  WORKSPACE
  PRIVATE
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  ARCHIVED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskRecurrenceFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

enum NotificationStatus {
  UNREAD
  READ
  ARCHIVED
}

model User {
  id                       String                @id @default(uuid()) @db.Uuid
  email                    String                @unique @db.Citext
  name                     String
  passwordHash             String                @map("password_hash")
  avatarUrl                String?               @map("avatar_url")
  disabledAt               DateTime?             @map("disabled_at") @db.Timestamptz(6)
  createdAt                DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt                DateTime?             @map("deleted_at") @db.Timestamptz(6)
  sessions                 Session[]
  oauthAccounts            OAuthAccount[]
  workspaceLinks           WorkspaceMember[]
  sentWorkspaceInvitations WorkspaceInvitation[] @relation("WorkspaceInvitationInviter")
  ownedWorkspaces          Workspace[]           @relation("WorkspaceOwner")
  createdProjects          Project[]             @relation("ProjectCreator")
  createdProjectTemplates  ProjectTemplate[]     @relation("ProjectTemplateCreator")
  projectTemplateTaskAssignees ProjectTemplateTaskAssignee[]
  projectMessages          ProjectMessage[]      @relation("ProjectMessageAuthor")
  pinnedProjectMessages    ProjectMessage[]      @relation("ProjectMessagePinnedBy")
  projectLinks             ProjectMember[]
  assignedTasks            TaskAssignee[]
  taskWatches              TaskWatcher[]         @relation("TaskWatcherUser")
  createdTaskWatches       TaskWatcher[]         @relation("TaskWatcherWatchedBy")
  subtasks                 Subtask[]             @relation("SubtaskAssignee")
  comments                 Comment[]
  attachments              Attachment[]
  attachmentVersions       AttachmentVersion[]   @relation("AttachmentVersionUploader")
  activityEvents           ActivityEvent[]       @relation("ActivityActor")
  notifications            Notification[]        @relation("NotificationRecipient")
  notificationPreferences  WorkspaceNotificationPreference[]
  assignedTaskLabels       TaskLabelAssignment[] @relation("TaskLabelAssignedBy")
  createdTaskDependencies  TaskDependency[]      @relation("TaskDependencyCreatedBy")

  @@index([deletedAt])
  @@map("users")
}

model Session {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  refreshTokenHash String    @map("refresh_token_hash")
  tokenFamily      String    @map("token_family") @db.Uuid
  ipAddress        String?   @map("ip_address")
  userAgent        String?   @map("user_agent")
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([tokenFamily])
  @@map("sessions")
}

model OAuthAccount {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  provider          String
  providerAccountId String    @map("provider_account_id")
  accessToken       String?   @map("access_token")
  refreshToken      String?   @map("refresh_token")
  expiresAt         DateTime? @map("expires_at") @db.Timestamptz(6)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("oauth_accounts")
}

model Workspace {
  id            String                @id @default(uuid()) @db.Uuid
  name          String
  slug          String                @unique
  ownerId       String                @map("owner_id") @db.Uuid
  createdAt     DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime?             @map("deleted_at") @db.Timestamptz(6)
  owner         User                  @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  members       WorkspaceMember[]
  invitations   WorkspaceInvitation[]
  projects      Project[]
  projectTemplates ProjectTemplate[]
  projectMessages ProjectMessage[]
  activity      ActivityEvent[]
  notifications Notification[]
  notificationPreferences WorkspaceNotificationPreference[]
  taskLabels    TaskLabel[]
  taskLabelAssignments TaskLabelAssignment[]
  taskWatchers  TaskWatcher[]
  taskDependencies TaskDependency[]
  workerJobOutcomes WorkerJobOutcome[]

  @@index([ownerId])
  @@index([deletedAt])
  @@map("workspaces")
}

model WorkspaceMember {
  id          String        @id @default(uuid()) @db.Uuid
  workspaceId String        @map("workspace_id") @db.Uuid
  userId      String        @map("user_id") @db.Uuid
  role        WorkspaceRole @default(MEMBER)
  invitedById String?       @map("invited_by_id") @db.Uuid
  joinedAt    DateTime?     @map("joined_at") @db.Timestamptz(6)
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?     @map("deleted_at") @db.Timestamptz(6)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@index([workspaceId, role])
  @@map("workspace_members")
}

model WorkspaceInvitation {
  id           String        @id @default(uuid()) @db.Uuid
  workspaceId  String        @map("workspace_id") @db.Uuid
  email        String        @db.Citext
  role         WorkspaceRole @default(MEMBER)
  tokenHash    String        @unique @map("token_hash")
  invitedById  String        @map("invited_by_id") @db.Uuid
  acceptedById String?       @map("accepted_by_id") @db.Uuid
  expiresAt    DateTime      @map("expires_at") @db.Timestamptz(6)
  acceptedAt   DateTime?     @map("accepted_at") @db.Timestamptz(6)
  declinedAt   DateTime?     @map("declined_at") @db.Timestamptz(6)
  canceledAt   DateTime?     @map("canceled_at") @db.Timestamptz(6)
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy    User          @relation("WorkspaceInvitationInviter", fields: [invitedById], references: [id])

  @@index([workspaceId, email])
  @@index([workspaceId, canceledAt, acceptedAt, declinedAt])
  @@index([expiresAt])
  @@map("workspace_invitations")
}

model Project {
  id          String            @id @default(uuid()) @db.Uuid
  workspaceId String            @map("workspace_id") @db.Uuid
  name        String
  description String?
  visibility  ProjectVisibility @default(WORKSPACE)
  createdById String            @map("created_by_id") @db.Uuid
  archivedAt  DateTime?         @map("archived_at") @db.Timestamptz(6)
  createdAt   DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?         @map("deleted_at") @db.Timestamptz(6)
  workspace   Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy   User              @relation("ProjectCreator", fields: [createdById], references: [id])
  members     ProjectMember[]
  sections    Section[]
  tasks       Task[]
  messages    ProjectMessage[]
  activity    ActivityEvent[]

  @@index([workspaceId, deletedAt])
  @@index([workspaceId, visibility])
  @@map("projects")
}

model ProjectMember {
  id        String      @id @default(uuid()) @db.Uuid
  projectId String      @map("project_id") @db.Uuid
  userId    String      @map("user_id") @db.Uuid
  role      ProjectRole @default(EDITOR)
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime?   @map("deleted_at") @db.Timestamptz(6)
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
  @@map("project_members")
}

model ProjectMessage {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  projectId   String    @map("project_id") @db.Uuid
  authorId    String    @map("author_id") @db.Uuid
  title       String
  body        String
  pinnedAt    DateTime? @map("pinned_at") @db.Timestamptz(6)
  pinnedById  String?   @map("pinned_by_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author      User      @relation("ProjectMessageAuthor", fields: [authorId], references: [id])
  pinnedBy    User?     @relation("ProjectMessagePinnedBy", fields: [pinnedById], references: [id], onDelete: SetNull)

  @@index([workspaceId, projectId, createdAt])
  @@index([workspaceId, projectId, pinnedAt])
  @@index([workspaceId, authorId])
  @@map("project_messages")
}

model ProjectTemplate {
  id          String                   @id @default(uuid()) @db.Uuid
  workspaceId String                   @map("workspace_id") @db.Uuid
  name        String
  description String?
  createdById String                   @map("created_by_id") @db.Uuid
  createdAt   DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?                @map("deleted_at") @db.Timestamptz(6)
  workspace   Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy   User                     @relation("ProjectTemplateCreator", fields: [createdById], references: [id])
  sections    ProjectTemplateSection[]
  tasks       ProjectTemplateTask[]

  @@index([workspaceId, deletedAt, createdAt])
  @@index([createdById])
  @@map("project_templates")
}

model ProjectTemplateSection {
  id          String                @id @default(uuid()) @db.Uuid
  workspaceId String                @map("workspace_id") @db.Uuid
  templateId  String                @map("template_id") @db.Uuid
  name        String
  position    Decimal               @db.Decimal(20, 10)
  createdAt   DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  template    ProjectTemplate       @relation(fields: [templateId], references: [id], onDelete: Cascade)
  tasks       ProjectTemplateTask[]

  @@unique([templateId, position])
  @@index([workspaceId, templateId])
  @@map("project_template_sections")
}

model ProjectTemplateTask {
  id          String                 @id @default(uuid()) @db.Uuid
  workspaceId String                 @map("workspace_id") @db.Uuid
  templateId  String                 @map("template_id") @db.Uuid
  sectionId   String                 @map("section_id") @db.Uuid
  title       String
  description String?
  priority    TaskPriority           @default(MEDIUM)
  dueDateOffsetDays Int?             @map("due_date_offset_days")
  position    Decimal                @db.Decimal(20, 10)
  createdAt   DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  template    ProjectTemplate        @relation(fields: [templateId], references: [id], onDelete: Cascade)
  section     ProjectTemplateSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  assignees        ProjectTemplateTaskAssignee[]
  labelAssignments ProjectTemplateTaskLabelAssignment[]

  @@index([workspaceId, templateId])
  @@index([workspaceId, sectionId, position])
  @@map("project_template_tasks")
}

model ProjectTemplateTaskAssignee {
  id             String              @id @default(uuid()) @db.Uuid
  workspaceId    String              @map("workspace_id") @db.Uuid
  templateTaskId String              @map("template_task_id") @db.Uuid
  userId         String              @map("user_id") @db.Uuid
  createdAt      DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  templateTask   ProjectTemplateTask @relation(fields: [templateTaskId], references: [id], onDelete: Cascade)
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([templateTaskId, userId])
  @@index([workspaceId, userId])
  @@index([workspaceId, templateTaskId])
  @@map("project_template_task_assignees")
}

model ProjectTemplateTaskLabelAssignment {
  id             String              @id @default(uuid()) @db.Uuid
  workspaceId    String              @map("workspace_id") @db.Uuid
  templateTaskId String              @map("template_task_id") @db.Uuid
  labelId        String              @map("label_id") @db.Uuid
  createdAt      DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  templateTask   ProjectTemplateTask @relation(fields: [templateTaskId], references: [id], onDelete: Cascade)
  label          TaskLabel           @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([templateTaskId, labelId])
  @@index([workspaceId, labelId])
  @@index([workspaceId, templateTaskId])
  @@map("project_template_task_label_assignments")
}

model Section {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  projectId   String    @map("project_id") @db.Uuid
  name        String
  position    Decimal   @db.Decimal(20, 10)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks       Task[]

  @@unique([projectId, position])
  @@index([workspaceId, projectId, deletedAt])
  @@map("sections")
}

model Task {
  id            String          @id @default(uuid()) @db.Uuid
  workspaceId   String          @map("workspace_id") @db.Uuid
  projectId     String          @map("project_id") @db.Uuid
  sectionId     String          @map("section_id") @db.Uuid
  title         String
  description   String?
  status        TaskStatus      @default(TODO)
  priority      TaskPriority    @default(MEDIUM)
  dueDate       DateTime?       @map("due_date") @db.Date
  position      Decimal         @db.Decimal(20, 10)
  completedAt   DateTime?       @map("completed_at") @db.Timestamptz(6)
  recurrenceFrequency TaskRecurrenceFrequency? @map("recurrence_frequency")
  recurrenceInterval Int? @map("recurrence_interval")
  recurrenceEndDate DateTime? @map("recurrence_end_date") @db.Date
  recurrenceGeneratedFromTaskId String? @unique @map("recurrence_generated_from_task_id") @db.Uuid
  recurrencePausedAt DateTime? @map("recurrence_paused_at") @db.Timestamptz(6)
  recurrenceSkippedAt DateTime? @map("recurrence_skipped_at") @db.Timestamptz(6)
  version       Int             @default(0)
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime?       @map("deleted_at") @db.Timestamptz(6)
  project       Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  section       Section         @relation(fields: [sectionId], references: [id])
  recurrenceGeneratedFromTask Task? @relation("TaskRecurrenceGeneratedFrom", fields: [recurrenceGeneratedFromTaskId], references: [id], onDelete: SetNull)
  recurrenceGeneratedTasks Task[] @relation("TaskRecurrenceGeneratedFrom")
  assignees     TaskAssignee[]
  watchers      TaskWatcher[]
  subtasks      Subtask[]
  comments      Comment[]
  attachments   Attachment[]
  activity      ActivityEvent[]
  notifications Notification[]
  labelAssignments TaskLabelAssignment[]
  dependenciesAsBlocker TaskDependency[] @relation("TaskDependencyBlocking")
  dependenciesAsBlocked TaskDependency[] @relation("TaskDependencyBlocked")

  @@index([workspaceId, projectId, deletedAt])
  @@index([workspaceId, sectionId, position])
  @@index([workspaceId, recurrenceFrequency])
  @@index([workspaceId, recurrencePausedAt])
  @@index([workspaceId, status])
  @@index([workspaceId, dueDate])
  @@map("tasks")
}

model TaskAssignee {
  id           String   @id @default(uuid()) @db.Uuid
  workspaceId  String   @map("workspace_id") @db.Uuid
  taskId       String   @map("task_id") @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  assignedById String?  @map("assigned_by_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([workspaceId, userId])
  @@map("task_assignees")
}

model TaskWatcher {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  taskId      String   @map("task_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  watchedById String?  @map("watched_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user        User     @relation("TaskWatcherUser", fields: [userId], references: [id], onDelete: Cascade)
  watchedBy   User?    @relation("TaskWatcherWatchedBy", fields: [watchedById], references: [id])

  @@unique([taskId, userId])
  @@index([workspaceId, userId])
  @@index([workspaceId, taskId])
  @@map("task_watchers")
}

model TaskLabel {
  id          String                @id @default(uuid()) @db.Uuid
  workspaceId String                @map("workspace_id") @db.Uuid
  name        String
  color       String
  createdAt   DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?             @map("deleted_at") @db.Timestamptz(6)
  workspace   Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assignments TaskLabelAssignment[]
  templateAssignments ProjectTemplateTaskLabelAssignment[]

  @@unique([workspaceId, name])
  @@index([workspaceId, deletedAt])
  @@map("task_labels")
}

model TaskLabelAssignment {
  id           String    @id @default(uuid()) @db.Uuid
  workspaceId  String    @map("workspace_id") @db.Uuid
  taskId       String    @map("task_id") @db.Uuid
  labelId      String    @map("label_id") @db.Uuid
  assignedById String?   @map("assigned_by_id") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  task         Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label        TaskLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)
  assignedBy   User?     @relation("TaskLabelAssignedBy", fields: [assignedById], references: [id])

  @@unique([taskId, labelId])
  @@index([workspaceId, labelId])
  @@index([workspaceId, taskId])
  @@map("task_label_assignments")
}

model TaskDependency {
  id             String    @id @default(uuid()) @db.Uuid
  workspaceId    String    @map("workspace_id") @db.Uuid
  blockingTaskId String    @map("blocking_task_id") @db.Uuid
  blockedTaskId  String    @map("blocked_task_id") @db.Uuid
  createdById    String?   @map("created_by_id") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  blockingTask   Task      @relation("TaskDependencyBlocking", fields: [blockingTaskId], references: [id], onDelete: Cascade)
  blockedTask    Task      @relation("TaskDependencyBlocked", fields: [blockedTaskId], references: [id], onDelete: Cascade)
  createdBy      User?     @relation("TaskDependencyCreatedBy", fields: [createdById], references: [id])

  @@unique([blockingTaskId, blockedTaskId])
  @@index([workspaceId, blockedTaskId])
  @@index([workspaceId, blockingTaskId])
  @@map("task_dependencies")
}

model Subtask {
  id          String     @id @default(uuid()) @db.Uuid
  workspaceId String     @map("workspace_id") @db.Uuid
  taskId      String     @map("task_id") @db.Uuid
  title       String
  status      TaskStatus @default(TODO)
  assigneeId  String?    @map("assignee_id") @db.Uuid
  position    Decimal    @db.Decimal(20, 10)
  completedAt DateTime?  @map("completed_at") @db.Timestamptz(6)
  version     Int        @default(0)
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?  @map("deleted_at") @db.Timestamptz(6)
  task        Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  assignee    User?      @relation("SubtaskAssignee", fields: [assigneeId], references: [id])

  @@index([workspaceId, taskId, deletedAt])
  @@map("subtasks")
}

model Comment {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  taskId      String    @map("task_id") @db.Uuid
  authorId    String    @map("author_id") @db.Uuid
  body        String
  editedAt    DateTime? @map("edited_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author      User      @relation(fields: [authorId], references: [id])

  @@index([workspaceId, taskId, createdAt])
  @@map("comments")
}

model Attachment {
  id           String    @id @default(uuid()) @db.Uuid
  workspaceId  String    @map("workspace_id") @db.Uuid
  taskId       String    @map("task_id") @db.Uuid
  uploadedById String    @map("uploaded_by_id") @db.Uuid
  objectKey    String    @map("object_key")
  fileName     String    @map("file_name")
  mimeType     String    @map("mime_type")
  sizeBytes    Int       @map("size_bytes")
  description  String?
  version      Int       @default(1)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)
  task         Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedBy   User      @relation(fields: [uploadedById], references: [id])
  versions     AttachmentVersion[]

  @@unique([workspaceId, objectKey])
  @@index([workspaceId, taskId])
  @@index([workspaceId, uploadedById])
  @@map("attachments")
}

model AttachmentVersion {
  id           String    @id @default(uuid()) @db.Uuid
  workspaceId  String    @map("workspace_id") @db.Uuid
  attachmentId String    @map("attachment_id") @db.Uuid
  uploadedById String    @map("uploaded_by_id") @db.Uuid
  version      Int
  objectKey    String    @map("object_key")
  fileName     String    @map("file_name")
  mimeType     String    @map("mime_type")
  sizeBytes    Int       @map("size_bytes")
  activatedAt  DateTime? @map("activated_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  attachment   Attachment @relation(fields: [attachmentId], references: [id], onDelete: Cascade)
  uploadedBy   User      @relation("AttachmentVersionUploader", fields: [uploadedById], references: [id])

  @@unique([workspaceId, attachmentId, version])
  @@unique([workspaceId, objectKey])
  @@index([workspaceId, attachmentId, activatedAt])
  @@index([workspaceId, uploadedById])
  @@map("attachment_versions")
}

model ActivityEvent {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  projectId   String?   @map("project_id") @db.Uuid
  taskId      String?   @map("task_id") @db.Uuid
  actorUserId String    @map("actor_user_id") @db.Uuid
  eventType   String    @map("event_type")
  entityType  String    @map("entity_type")
  entityId    String    @map("entity_id") @db.Uuid
  payload     Json
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  task        Task?     @relation(fields: [taskId], references: [id], onDelete: SetNull)
  actor       User      @relation("ActivityActor", fields: [actorUserId], references: [id])

  @@index([workspaceId, createdAt])
  @@index([workspaceId, projectId, createdAt])
  @@index([workspaceId, taskId, createdAt])
  @@map("activity_events")
}

model DomainEventOutbox {
  id            String                      @id @default(uuid()) @db.Uuid
  eventId       String                      @unique @map("event_id") @db.Uuid
  eventType     String                      @map("event_type")
  payload       Json
  attempts      Int                         @default(0)
  nextAttemptAt DateTime?                   @map("next_attempt_at") @db.Timestamptz(6)
  lockedAt      DateTime?                   @map("locked_at") @db.Timestamptz(6)
  processedAt   DateTime?                   @map("processed_at") @db.Timestamptz(6)
  failedAt      DateTime?                   @map("failed_at") @db.Timestamptz(6)
  lastError     String?                     @map("last_error")
  createdAt     DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime                    @updatedAt @map("updated_at") @db.Timestamptz(6)
  attemptsLog   DomainEventOutboxAttempt[]

  @@index([processedAt, failedAt, nextAttemptAt])
  @@index([eventType])
  @@map("domain_event_outbox")
}

model DomainEventOutboxAttempt {
  id            String            @id @default(uuid()) @db.Uuid
  outboxEventId String            @map("outbox_event_id") @db.Uuid
  attemptNumber Int               @map("attempt_number")
  status        String
  startedAt     DateTime          @map("started_at") @db.Timestamptz(6)
  finishedAt    DateTime          @map("finished_at") @db.Timestamptz(6)
  error         String?
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  outboxEvent   DomainEventOutbox @relation(fields: [outboxEventId], references: [id], onDelete: Cascade)

  @@unique([outboxEventId, attemptNumber])
  @@index([outboxEventId, createdAt])
  @@map("domain_event_outbox_attempts")
}

model Notification {
  id          String             @id @default(uuid()) @db.Uuid
  workspaceId String             @map("workspace_id") @db.Uuid
  recipientId String             @map("recipient_id") @db.Uuid
  taskId      String?            @map("task_id") @db.Uuid
  type        String
  title       String
  body        String
  status      NotificationStatus @default(UNREAD)
  readAt      DateTime?          @map("read_at") @db.Timestamptz(6)
  createdAt   DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  workspace   Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  recipient   User               @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  task        Task?              @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([workspaceId, recipientId, status, createdAt])
  @@map("notifications")
}

model WorkspaceNotificationPreference {
  id           String    @id @default(uuid()) @db.Uuid
  workspaceId  String    @map("workspace_id") @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  emailEnabled Boolean   @default(false) @map("email_enabled")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@map("workspace_notification_preferences")
}

model WorkerJobOutcome {
  id                String    @id @default(uuid()) @db.Uuid
  workspaceId       String    @map("workspace_id") @db.Uuid
  eventId           String    @map("event_id") @db.Uuid
  eventType         String    @map("event_type")
  entityType        String    @map("entity_type")
  entityId          String    @map("entity_id") @db.Uuid
  queue             String
  status            String
  reason            String?
  provider          String?
  providerMessageId String?   @map("provider_message_id")
  recipientCount    Int?      @map("recipient_count")
  jobId             String?   @map("job_id")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  workspace         Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, eventId, createdAt])
  @@index([workspaceId, queue, createdAt])
  @@index([workspaceId, status, createdAt])
  @@map("worker_job_outcomes")
}
